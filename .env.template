# =========================================================================
# AURA RAG - System Environment Configuration Template
# =========================================================================

# API Keys (At least one must be configured to run query generation & evaluation)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Core Configuration
# Choose LLM/Embedding provider: 'gemini' (recommended) or 'openai'
LLM_PROVIDER=gemini

# Gemini Configurations
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# OpenAI Configurations
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG Splitting Parameters
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# Storage
VECTOR_STORE_PATH=vector_store.json

# API Server Configurations
HOST=0.0.0.0
PORT=8000
